{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Backend - Install & Prisma",
      "type": "shell",
      "command": "cd backend && npm install && npx prisma generate && npx prisma migrate dev --name init",
      "inAgents": true,
      "runOptions": { "runOn": "worktreeCreated" },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false
      }
    },

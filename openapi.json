        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing, expired, or reused token."
          }
        },
        "summary": "Rotate the refresh token",
        "tags": [
          "Auth"
        ]
      }
    },

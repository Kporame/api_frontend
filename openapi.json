  "info": {
    "title": "E-License Verification Platform API",
    "description": "REST API for the Thai e-licensing platform that plugs into the ทางรัฐ\n(Tang Rat) super app. Serves the public app and the admin portal.\n\n**Authentication.** Most endpoints require a Bearer access token\n(RS256 JWT, 15-min TTY). Obtain one from `POST /api/auth/tang-rat`\n(PUBLIC/INSPECTOR/SUPERVISOR) or `POST /api/auth/self` (ADMIN).\nClick **Authorize** and paste the `accessToken` to call protected routes.\n\n**Scope.** INSPECTOR/SUPERVISOR responses are filtered server-side by the\ncaller's zones and agency; clients cannot widen scope via query params.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Login, token refresh, logout, and password management"
    },
    {
      "name": "Licenses",
      "description": "Public license type, detail, and QR verification"
    },
    {
      "name": "Businesses",
      "description": "Public business search, detail, and map"
    },
    {
      "name": "My",
      "description": "Authenticated user self-service (licenses)"
    },
    {
      "name": "Notifications",
      "description": "In-app notifications for the current user"
    },
    {
      "name": "Inspection",
      "description": "Inspection tasks and reports state machine"
    },
    {
      "name": "Dashboards",
      "description": "Role-specific aggregate dashboards"
    },
    {
      "name": "Users",
      "description": "User administration (admin / supervisor)"
    },
    {
      "name": "Zones",
      "description": "Zone master data"
    },
    {
      "name": "Sync",
      "description": "Agency data sync and CSV import"
    },
    {
      "name": "Audit",
      "description": "Audit log listing"
    },
    {
      "name": "Export",
      "description": "PDF/XLSX exports"
    }
  ],

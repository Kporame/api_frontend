    "/api/auth/tang-rat": {
      "post": {
        "description": "Verifies the mToken with the Tang Rat provider, finds or creates the user, and issues access + refresh tokens. Sets the refresh token as an httpOnly cookie.",
        "operationId": "AuthController_tangRat",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TangRatLoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid mToken or inactive user."
          }
        },
        "summary": "Login via ทางรัฐ mToken (PUBLIC / INSPECTOR / SUPERVISOR)",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/self": {
      "post": {
        "description": "Admin self-login. On first login (mustChangePassword) returns a `tempToken` and `requiresPasswordChange: true` instead of tokens. Rate limited to 10/min/IP. Account locks for 15 min after 5 failures.",
        "operationId": "AuthController_self",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SelfLoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tokens, or a password-change challenge on first login.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials or TOTP."
          }
        },
        "summary": "Login with username + password + TOTP (ADMIN only)",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/refresh": {
      "post": {
        "description": "Issues a new access + refresh token pair and revokes the old session (rotation). Replaying an already-rotated token is treated as theft and revokes all of the user’s sessions. Token may come from the body or the `refreshToken` cookie.",
        "operationId": "AuthController_refresh",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshDto"

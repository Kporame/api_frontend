generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Team {
  id          String    @id @default(uuid())
  name        String
  description String?
  users       User[]
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  name            String
  role            String            @default("GUEST") // GUEST, DEVELOPER, ADMIN
  teamId          String?
  team            Team?             @relation(fields: [teamId], references: [id])
  projectAccesses ProjectAccess[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Project {
  id          String            @id @default(uuid())
  name        String
  description String?
  githubUrl   String?
  domainUrl   String?
  documentUrl String?
  visibility  String            @default("INTERNAL") // PUBLIC, INTERNAL, PRIVATE
  teamId      String
  team        Team              @relation(fields: [teamId], references: [id])
  documents   ApiDocument[]
  accesses    ProjectAccess[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ProjectAccess {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("VIEWER") // VIEWER, EDITOR, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
}

model ApiDocument {
  id        String        @id @default(uuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  fileName  String        @default("document")
  fileType  String        @default("unknown") // "swagger" or "postman"
  version   String        @default("1.0.0")
  rawFile   String        // The original JSON/YAML string
  endpoints ApiEndpoint[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ApiEndpoint {
  id             String      @id @default(uuid())
  documentId     String
  document       ApiDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  method         String      // GET, POST, PUT, DELETE
  path           String      // e.g., /api/users
  title          String
  description    String?
  requestHeaders String?     // Stored as JSON string
  requestBody    String?     // Stored as JSON string
  responseBody   String?     // Stored as JSON string
  responseStatus String?     // e.g., 200 OK
  isPublic       Boolean     @default(false) // Granular Visibility for endpoints
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model AuditLog {
  id            String    @id @default(uuid())
  userId        String?   // Who performed the action
  action        String    // login, upload, test_request, visibility_change, etc.
  endpointPath  String?   // Target API path (for test requests)
  requestUrl    String?   // Full target URL (masked)
  requestMethod String?   // GET, POST, etc.
  requestBody   String?   // Request body (masked for sensitive data)
  responseStatus Int?     // HTTP status code
  responseTime  Int?      // Response time in ms
  ipAddress     String?   // Client IP
  userAgent     String?   // Browser/client info
  details       String?   // Additional context as JSON
  isMasked      Boolean   @default(false) // Whether sensitive data was masked
  createdAt     DateTime  @default(now())
}
